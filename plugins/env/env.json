{
  "marketplaces": [
    {
      "name": "omc",
      "git": "https://github.com/Yeachan-Heo/oh-my-claudecode.git"
    },
    {
      "name": "claude-skill",
      "repo": "litbig-git/claude-skill"
    }
  ],
  "plugins": {
    "dev@jacob-plugin": "latest",
    "oh-my-claudecode@omc": "latest",
    "oss-report@claude-skill": "latest",
    "ui-scenario@claude-skill": "latest",
    "log-analysis@claude-skill": "latest",
    "auto-release@claude-skill": "latest",
    "project-schedule@claude-skill": "latest",
    "gantt-chart@claude-skill": "latest",
    "fund-plan@claude-skill": "latest",
    "promo-script@claude-skill": "latest",
    "notebooklm@claude-skill": "latest",
    "youtube-share@claude-skill": "latest",
    "session-cleanup@claude-skill": "latest",
    "checkerboard-marker@claude-skill": "latest",
    "pre-commit-gate@claude-skill": "latest"
  },
  "clis": [
    {
      "name": "jira",
      "check": "jira version",
      "install": "go install github.com/ankitpokhrel/jira-cli/cmd/jira@latest"
    },
    {
      "name": "gws",
      "check": "gws --version",
      "install": "pip install gws-cli"
    }
  ],
  "mcpServers": {},
  "hooks": {},
  "settings": {
    "env": {
      "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",
      "CLAUDE_CODE_NO_FLICKER": "1"
    },
    "statusLine": {
      "type": "command",
      "command": "node ${HOME}/.claude/hud/omc-hud.mjs"
    },
    "language": "korean",
    "effortLevel": "high",
    "autoUpdatesChannel": "latest",
    "skipDangerousModePermissionPrompt": true
  }
}
